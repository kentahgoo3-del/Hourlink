modules = ["nodejs-20", "nodejs-24"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["resend:1.0.0", "revenuecat:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["psmisc", "lsof"]

[userenv]

[userenv.shared]
REVENUECAT_PROJECT_ID = "proj0fd45034"
REVENUECAT_TEST_STORE_APP_ID = "appbe8ab92c20"
REVENUECAT_APPLE_APP_STORE_APP_ID = "app17924d76fa"
REVENUECAT_GOOGLE_PLAY_STORE_APP_ID = "app63ce0d4074"
EXPO_PUBLIC_REVENUECAT_TEST_API_KEY = "test_YSLLRGzMRIvUzMnJoqrSCYnGtgO"
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY = "appl_qMOiDBZRwNHoXOQZEIMhqjxszVc"
